# EduSphere AI — local environment
# Copy of .env.example with the AI provider set to the FREE OpenRouter path.
# This file is git-ignored.

# --- FREE AI (OpenRouter) -------------------------------------------------
# 1) Go to https://openrouter.ai/keys and create a free key (no credit card).
# 2) Paste it below. The default model is a free Llama model.
# The assistant will then give REAL answers with $0 cost.
VITE_AI_PROVIDER=openai
VITE_AI_BASE_URL=https://openrouter.ai/api/v1
VITE_AI_API_KEY=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
VITE_AI_MODEL=google/gemma-4-31b-it:free

# Keep Gemini key too (used if you switch VITE_AI_PROVIDER back to 'gemini').
VITE_GEMINI_API_KEY=AQ.Ab8RN6Ihgmq9Qy8CCGK-H8uTMZBXb7AkPiVMDB3lj6h3ENfdcg
VITE_GEMINI_MODEL=gemini-2.0-flash

# VITE_FIREBASE_API_KEY=your-api-key
