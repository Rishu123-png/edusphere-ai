rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function getUser() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function role() { return getUser().role; }
    function schoolId() { return getUser().schoolId; }
    function isSchoolMember(sid) { return isSignedIn() && schoolId() == sid; }
    function isAdmin() { return role() in ['school_admin','principal','super_admin']; }
    function isTeacher() { return role() == 'teacher' || isAdmin(); }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin();
    }

    match /schools/{school} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (getUser().role in ['school_admin','super_admin'] && getUser().schoolId == school);
    }

    // Multi-tenant collections: students, teachers, attendance, marks, schedules
    match /students/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == schoolId();
      allow create, update, delete: if isTeacher() && request.resource.data.schoolId == schoolId();
    }
    match /attendance/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == schoolId();
      allow create, update: if isTeacher() && request.resource.data.schoolId == schoolId();
    }
    match /attendance_sessions/{id} {
      allow read, write: if isTeacher() && request.resource.data.schoolId == schoolId();
    }
    match /marks/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == schoolId();
      allow write: if isTeacher() && request.resource.data.schoolId == schoolId();
    }
    match /schedules/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == schoolId();
      allow write: if isAdmin() && request.resource.data.schoolId == schoolId();
    }
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == schoolId();
      allow write: if isTeacher() && request.resource.data.schoolId == schoolId();
    }
    // default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
